#!/bin/bash
# spirit-room - フォルダを精神と時の部屋として起動するCLI
#
# インストール:
#   sudo cp spirit-room /usr/local/bin/spirit-room
#   sudo chmod +x /usr/local/bin/spirit-room

set -e

BASE_IMAGE="spirit-room-base:latest"
AUTH_VOLUME="spirit-room-auth"        # 認証情報共有ボリューム（全部屋で使い回す）
OPENCODE_AUTH_VOLUME="spirit-room-opencode-auth"

usage() {
    cat << EOF
使い方:
  spirit-room open   [フォルダ]     部屋を開く（省略時はカレント）
  spirit-room kaio   [フォルダ]     界王星を開く（GSD駆動の本格開発モード・重力10倍）
  spirit-room enter  [フォルダ]     部屋に入る（SSH + tmux attach）
  spirit-room list                   起動中の部屋一覧
  spirit-room close  [フォルダ]     部屋を閉じる
  spirit-room logs   [フォルダ]     修行ログを見る
  spirit-room auth                   認証（初回のみ）

例:
  cd ~/projects/langgraph-poc && spirit-room open
  spirit-room open ~/projects/mastra-trial
  spirit-room kaio ~/projects/my-app
  spirit-room enter ~/projects/langgraph-poc
  spirit-room list
  spirit-room open --kochou ~/projects/compose-poc    # 胡蝶の夢 (DooD): docker compose が使える部屋
  spirit-room kaio --kochou ~/projects/my-app         # 界王星モードでも --kochou 対応
EOF
    exit 1
}

# ── フォルダパス → コンテナ名 ────────────────────────────────
folder_to_name() {
    local folder="${1:-$(pwd)}"
    folder=$(realpath "$folder")
    echo "spirit-room-$(basename $folder)" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g'
}

# ── 使用可能なSSHポートを探す ────────────────────────────────
find_free_port() {
    local port=2222
    while docker ps --format '{{.Ports}}' | grep -q ":${port}->"; do
        port=$((port + 1))
    done
    echo $port
}

# ── --kochou フラグ用追加 docker run 引数 ─────────────────────
# 胡蝶の夢モード (荘子): 部屋から host の docker daemon を叩ける DooD モード。
# 夢 (部屋) から現実 (host) を操作できる = 境界が溶ける感覚にちなむ命名。
# D-10: --kochou 指定時に docker run に追加する引数を 1 行 1 トークンで echo する
# 呼び出し側は mapfile -t で配列化すること (単語分割回避)
# 引数: $1=folder (realpath 済み絶対パス), $2=room_name
_kochou_extra_args() {
    local folder="$1"
    local room_name="$2"
    local host_docker_gid
    host_docker_gid=$(stat -c '%g' /var/run/docker.sock 2>/dev/null || echo "")

    # printf を使う: echo "-e" / "-v" だと bash 組み込み echo のフラグとして
    # 解釈されて消費されるため (backslash 解釈 ON / 改行抑制)、必ず printf で出力する
    printf '%s\n' \
        "-v" "/var/run/docker.sock:/var/run/docker.sock" \
        "--add-host=host.docker.internal:host-gateway" \
        "-e" "HOST_WORKSPACE=${folder}" \
        "-e" "SPIRIT_ROOM_HOST_GATEWAY=host.docker.internal" \
        "-e" "SPIRIT_ROOM_KOCHOU=1" \
        "-e" "COMPOSE_PROJECT_NAME=${room_name}"
    if [ -n "$host_docker_gid" ]; then
        printf '%s\n' "-e" "HOST_DOCKER_GID=${host_docker_gid}"
    fi
}

# ── host 認証情報をボリュームへ同期 (open/kaio 共用) ─────────
# Claude Code の OAuth トークンは短命なので、部屋起動ごとに host の
# 最新 ~/.claude/.credentials.json を AUTH_VOLUME の .credentials.json に
# 上書きコピーする。host に creds が無い場合は WARN のみで return し、
# 呼び出し側 (open/kaio) はそのまま docker run -d へ進める。
_sync_host_credentials() {
    local host_creds="${HOME}/.claude/.credentials.json"
    if [ ! -f "$host_creds" ]; then
        echo "[WARN] ホストに認証情報なし: $host_creds"
        echo "       spirit-room auth を先に実行してください"
        return 0
    fi

    echo "[INFO] ホストの最新認証情報をボリュームに同期中..."
    docker run --rm \
        -v "${AUTH_VOLUME}:/dst" \
        -v "${host_creds}:/src/.credentials.json:ro" \
        -e HOST_UID="$(id -u)" \
        -e HOST_GID="$(id -g)" \
        --entrypoint /bin/bash \
        "$BASE_IMAGE" \
        -c "cp /src/.credentials.json /dst/.credentials.json && chown \$HOST_UID:\$HOST_GID /dst/.credentials.json && chmod 600 /dst/.credentials.json" \
        > /dev/null 2>&1 || echo "[WARN] 認証情報同期に失敗"
}

# ── コマンド: open ───────────────────────────────────────────
cmd_open() {
    # D-11: --kochou はどの位置でも OK (先頭・末尾どちらでも解釈)
    local kochou_flag=0
    local args=()
    for _a in "$@"; do
        case "$_a" in
            --kochou) kochou_flag=1 ;;
            *) args+=("$_a") ;;
        esac
    done
    local folder="${args[0]:-$(pwd)}"
    folder=$(realpath "$folder")
    local name=$(folder_to_name "$folder")
    local port=$(find_free_port)

    if docker ps --format '{{.Names}}' | grep -q "^${name}$"; then
        echo "[INFO] 部屋 '$name' はすでに起動中です"
        echo "[INFO] 入室: spirit-room enter $folder"
        return
    fi

    echo "
╔══════════════════════════════════════════════╗
║  部屋を開く                                  ║
║  フォルダ : $folder
║  コンテナ : $name
║  SSHポート: $port
╚══════════════════════════════════════════════╝
"

    # D-19: 胡蝶の夢モード (--kochou) のセキュリティ警告 (確認プロンプトなし)
    if [ "$kochou_flag" = "1" ]; then
        echo "[WARN] 胡蝶の夢 (--kochou): /var/run/docker.sock をマウントしました。"
        echo "       夢か現か — 部屋から host の全 docker コンテナを操作できる (= ホスト root 相当)"
    fi

    # 認証ボリュームを先に作成（なければ）
    docker volume create "$AUTH_VOLUME"         > /dev/null 2>&1 || true
    docker volume create "$OPENCODE_AUTH_VOLUME" > /dev/null 2>&1 || true

    # host の Claude credentials を毎回 AUTH_VOLUME に同期 (Q4Q-01)
    _sync_host_credentials

    # D-10: --kochou 時の追加引数を mapfile で配列化 (1 行 1 トークン形式で空白安全)
    local _extra_args=()
    if [ "$kochou_flag" = "1" ]; then
        mapfile -t _extra_args < <(_kochou_extra_args "$folder" "$name")
    fi

    docker run -d \
        --name "$name" \
        --hostname "$name" \
        -e ROOM_NAME="$(basename "$folder")" \
        -e HOST_UID="$(id -u)" \
        -e HOST_GID="$(id -g)" \
        -e TZ="${TZ:-Asia/Tokyo}" \
        "${_extra_args[@]}" \
        -p "${port}:22" \
        -v "${folder}:/workspace" \
        -v "${AUTH_VOLUME}:/root/.claude" \
        -v "${OPENCODE_AUTH_VOLUME}:/root/.config/opencode" \
        -v "${HOME}/.claude.json:/root/.claude.json:ro" \
        "$BASE_IMAGE"

    echo "[INFO] 部屋を開きました"
    echo ""
    echo "  入室 : spirit-room enter $folder"
    echo "  または: ssh goku@localhost -p $port  (パス: spiritroom)"
    echo "  確認 : spirit-room list"
}

# ── コマンド: kaio (界王星モード) ────────────────────────────
# 重力10倍の界王星モード。CLAUDE_CONFIG_DIR=/workspace/.claude-home を設定し、
# 共有認証ボリュームは /root/.claude-shared にマウントする（entrypoint 側で
# プロジェクトローカル設定と統合される）。既存 cmd_open とは別コンテナ名で共存。
cmd_kaio() {
    # D-11/D-13: --kochou はどの位置でも OK。kaio 固有のロジックには影響しない
    local kochou_flag=0
    local args=()
    for _a in "$@"; do
        case "$_a" in
            --kochou) kochou_flag=1 ;;
            *) args+=("$_a") ;;
        esac
    done
    local folder="${args[0]:-$(pwd)}"
    folder=$(realpath "$folder")
    local name="$(folder_to_name "$folder")-kaio"
    local port=$(find_free_port)

    if docker ps --format '{{.Names}}' | grep -q "^${name}$"; then
        echo "[INFO] 界王星 '$name' はすでに起動中 — 入室します"
        cmd_enter "$folder"
        return
    fi

    echo "
╔══════════════════════════════════════════════╗
║  界王星を開く (重力10倍)                    ║
║  フォルダ : $folder
║  コンテナ : $name
║  SSHポート: $port
║  モード   : GSD 駆動・本格開発
╚══════════════════════════════════════════════╝
"

    # D-19: 胡蝶の夢モード (--kochou) のセキュリティ警告
    if [ "$kochou_flag" = "1" ]; then
        echo "[WARN] 胡蝶の夢 (--kochou): /var/run/docker.sock をマウントしました。"
        echo "       夢か現か — 部屋から host の全 docker コンテナを操作できる (= ホスト root 相当)"
    fi

    # 認証ボリュームを先に作成（なければ）
    docker volume create "$AUTH_VOLUME" > /dev/null 2>&1 || true

    # host の Claude credentials を毎回 AUTH_VOLUME に同期 (open/kaio 共用)
    _sync_host_credentials

    # D-10/D-13: --kochou 時の追加引数を mapfile で配列化 (認証同期の --rm docker run には含めない)
    local _extra_args=()
    if [ "$kochou_flag" = "1" ]; then
        mapfile -t _extra_args < <(_kochou_extra_args "$folder" "$name")
    fi

    docker run -d \
        --name "$name" \
        --hostname "$name" \
        -e ROOM_NAME="$(basename "$folder")" \
        -e CLAUDE_CONFIG_DIR=/workspace/.claude-home \
        -e HOST_UID="$(id -u)" \
        -e HOST_GID="$(id -g)" \
        -e TZ="${TZ:-Asia/Tokyo}" \
        "${_extra_args[@]}" \
        -p "${port}:22" \
        -v "${folder}:/workspace" \
        -v "${AUTH_VOLUME}:/root/.claude-shared" \
        -v "${HOME}/.claude.json:/root/.host-claude.json:ro" \
        "$BASE_IMAGE"

    echo "[INFO] 界王星を開きました"
    echo ""
    echo "  ホスト側ログ  : spirit-room logs  $folder"
    echo "  再入室        : spirit-room enter $folder"
    echo ""
    echo "[INFO] tmux セッションにアタッチ中..."
    # entrypoint.sh が tmux を立ち上げるまで少し待つ
    sleep 2
    cmd_enter "$folder"
}

# ── 実行中のコンテナを解決 (spirit-room / 界王星 両対応) ─────
# 通常モード名が無ければ -kaio サフィックス付きを探す
resolve_running_name() {
    local base="$1"
    if docker ps --format '{{.Names}}' | grep -q "^${base}$"; then
        echo "$base"
    elif docker ps --format '{{.Names}}' | grep -q "^${base}-kaio$"; then
        echo "${base}-kaio"
    else
        echo ""
    fi
}

# ── コマンド: enter ──────────────────────────────────────────
cmd_enter() {
    local folder="${1:-$(pwd)}"
    folder=$(realpath "$folder")
    local base=$(folder_to_name "$folder")
    local name=$(resolve_running_name "$base")

    if [ -z "$name" ]; then
        echo "[ERROR] 部屋 '$base' (または '${base}-kaio') は起動していません"
        echo "  起動: spirit-room open $folder"
        echo "     または: spirit-room kaio $folder"
        exit 1
    fi

    local port=$(docker port "$name" 22 | cut -d: -f2)
    echo "[INFO] 部屋[$name] に入室 (SSH port: $port)"
    ssh -o StrictHostKeyChecking=no \
        -o UserKnownHostsFile=/dev/null \
        -t goku@localhost -p "$port" \
        "tmux attach -t spirit-room || tmux new-session -s spirit-room"
}

# ── コマンド: list ───────────────────────────────────────────
cmd_list() {
    echo "起動中の部屋:"
    docker ps \
        --filter "name=spirit-room-" \
        --format "  {{.Names}}\t{{.Status}}\tSSH→{{.Ports}}" \
        | column -t
}

# ── コマンド: close ──────────────────────────────────────────
cmd_close() {
    local folder="${1:-$(pwd)}"
    folder=$(realpath "$folder")
    local base=$(folder_to_name "$folder")
    local name=$(resolve_running_name "$base")

    if [ -z "$name" ]; then
        echo "[ERROR] 部屋 '$base' (または '${base}-kaio') は起動していません"
        exit 1
    fi

    echo "[INFO] 部屋 '$name' を閉じます..."
    docker stop "$name" && docker rm "$name"

    # D-15〜D-18: compose project ラベルで兄弟コンテナを検索・削除
    # --kochou 未使用時も filter クエリを走らせてよい (ヒットしなければ no-op)
    local _siblings
    _siblings=$(docker ps -a --filter "label=com.docker.compose.project=${name}" -q 2>/dev/null || true)
    if [ -n "$_siblings" ]; then
        local _count
        _count=$(echo "$_siblings" | wc -l | tr -d ' ')
        echo "[INFO] 部屋に紐づく compose 兄弟コンテナを ${_count} 件発見 — 削除します"
        echo "$_siblings" | xargs -r docker rm -f
        echo "[INFO] 兄弟コンテナ ${_count} 件を削除しました"
    else
        echo "[INFO] 兄弟コンテナは見つかりませんでした"
    fi

    echo "[INFO] 完了（workspaceのファイルはフォルダに残っています）"
}

# ── コマンド: logs ───────────────────────────────────────────
cmd_logs() {
    local folder="${1:-$(pwd)}"
    folder=$(realpath "$folder")
    echo "[INFO] ログ: $folder/.logs/progress.log"
    tail -f "$folder/.logs/progress.log" 2>/dev/null || echo "ログなし（まだ修行が始まっていません）"
}

# ── コマンド: auth ───────────────────────────────────────────
cmd_auth() {
    local creds="${HOME}/.claude/.credentials.json"
    docker volume create "$AUTH_VOLUME" > /dev/null 2>&1 || true

    if [ -f "$creds" ]; then
        # ホストに認証済みの場合: credentials をボリュームにコピー
        echo "[INFO] ホストの認証情報をボリュームにコピーします..."
        docker run --rm \
            -v "${AUTH_VOLUME}:/root/.claude" \
            -v "${creds}:/src/.credentials.json:ro" \
            --entrypoint /bin/bash \
            "$BASE_IMAGE" \
            -c "cp /src/.credentials.json /root/.claude/.credentials.json"
        echo "[INFO] 認証情報をボリューム '$AUTH_VOLUME' に保存しました"
        echo "[INFO] 以降の全部屋でこの認証が使われます"
    else
        # ホスト未認証の場合: 手順を案内
        echo ""
        echo "╔══════════════════════════════════════════════╗"
        echo "║  初回認証が必要です                         ║"
        echo "╚══════════════════════════════════════════════╝"
        echo ""
        echo "ホスト側で claude auth login を実行してください:"
        echo ""
        echo "  1. 別ターミナルで: claude auth login"
        echo "  2. 表示された URL をブラウザで開く"
        echo "  3. 認証コードをターミナルに貼り付ける"
        echo "  4. 完了後、再度このコマンドを実行: spirit-room auth"
        echo ""
        echo "[ERROR] ホストに認証情報が見つかりません: $creds"
        exit 1
    fi
}

# ── メイン ───────────────────────────────────────────────────
case "${1:-}" in
    open)   cmd_open  "${@:2}" ;;
    kaio)   cmd_kaio  "${@:2}" ;;
    enter)  cmd_enter "${2:-}" ;;
    list)   cmd_list ;;
    close)  cmd_close "${2:-}" ;;
    logs)   cmd_logs  "${2:-}" ;;
    auth)   cmd_auth ;;
    *)      usage ;;
esac
