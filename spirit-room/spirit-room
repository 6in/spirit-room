#!/bin/bash
# spirit-room - フォルダを精神と時の部屋として起動するCLI
#
# インストール:
#   sudo cp spirit-room /usr/local/bin/spirit-room
#   sudo chmod +x /usr/local/bin/spirit-room

set -e

BASE_IMAGE="spirit-room-base:latest"
AUTH_VOLUME="spirit-room-auth"        # 認証情報共有ボリューム（全部屋で使い回す）
OPENCODE_AUTH_VOLUME="spirit-room-opencode-auth"

usage() {
    cat << EOF
使い方:
  spirit-room open   [フォルダ]     部屋を開く（省略時はカレント）
  spirit-room kaio   [フォルダ]     界王星を開く（GSD駆動の本格開発モード・重力10倍）
  spirit-room enter  [フォルダ]     部屋に入る（SSH + tmux attach）
  spirit-room list                   起動中の部屋一覧
  spirit-room close  [フォルダ]     部屋を閉じる
  spirit-room logs   [フォルダ]     修行ログを見る
  spirit-room auth                   認証（初回のみ）

例:
  cd ~/projects/langgraph-poc && spirit-room open
  spirit-room open ~/projects/mastra-trial
  spirit-room kaio ~/projects/my-app
  spirit-room enter ~/projects/langgraph-poc
  spirit-room list
EOF
    exit 1
}

# ── フォルダパス → コンテナ名 ────────────────────────────────
folder_to_name() {
    local folder="${1:-$(pwd)}"
    folder=$(realpath "$folder")
    echo "spirit-room-$(basename $folder)" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g'
}

# ── 使用可能なSSHポートを探す ────────────────────────────────
find_free_port() {
    local port=2222
    while docker ps --format '{{.Ports}}' | grep -q ":${port}->"; do
        port=$((port + 1))
    done
    echo $port
}

# ── コマンド: open ───────────────────────────────────────────
cmd_open() {
    local folder="${1:-$(pwd)}"
    folder=$(realpath "$folder")
    local name=$(folder_to_name "$folder")
    local port=$(find_free_port)

    if docker ps --format '{{.Names}}' | grep -q "^${name}$"; then
        echo "[INFO] 部屋 '$name' はすでに起動中です"
        echo "[INFO] 入室: spirit-room enter $folder"
        return
    fi

    echo "
╔══════════════════════════════════════════════╗
║  部屋を開く                                  ║
║  フォルダ : $folder
║  コンテナ : $name
║  SSHポート: $port
╚══════════════════════════════════════════════╝
"

    # 認証ボリュームを先に作成（なければ）
    docker volume create "$AUTH_VOLUME"         > /dev/null 2>&1 || true
    docker volume create "$OPENCODE_AUTH_VOLUME" > /dev/null 2>&1 || true

    docker run -d \
        --name "$name" \
        --hostname "$name" \
        -e ROOM_NAME="$(basename $folder)" \
        -e HOST_UID="$(id -u)" \
        -e HOST_GID="$(id -g)" \
        -p "${port}:22" \
        -v "${folder}:/workspace" \
        -v "${AUTH_VOLUME}:/root/.claude" \
        -v "${OPENCODE_AUTH_VOLUME}:/root/.config/opencode" \
        -v "${HOME}/.claude.json:/root/.claude.json:ro" \
        "$BASE_IMAGE"

    echo "[INFO] 部屋を開きました"
    echo ""
    echo "  入室 : spirit-room enter $folder"
    echo "  または: ssh root@localhost -p $port  (パス: spiritroom)"
    echo "  確認 : spirit-room list"
}

# ── コマンド: kaio (界王星モード) ────────────────────────────
# 重力10倍の界王星モード。CLAUDE_CONFIG_DIR=/workspace/.claude-home を設定し、
# 共有認証ボリュームは /root/.claude-shared にマウントする（entrypoint 側で
# プロジェクトローカル設定と統合される）。既存 cmd_open とは別コンテナ名で共存。
cmd_kaio() {
    local folder="${1:-$(pwd)}"
    folder=$(realpath "$folder")
    local name="$(folder_to_name "$folder")-kaio"
    local port=$(find_free_port)

    if docker ps --format '{{.Names}}' | grep -q "^${name}$"; then
        echo "[INFO] 界王星 '$name' はすでに起動中 — 入室します"
        cmd_enter "$folder"
        return
    fi

    echo "
╔══════════════════════════════════════════════╗
║  界王星を開く (重力10倍)                    ║
║  フォルダ : $folder
║  コンテナ : $name
║  SSHポート: $port
║  モード   : GSD 駆動・本格開発
╚══════════════════════════════════════════════╝
"

    # 認証ボリュームを先に作成（なければ）
    docker volume create "$AUTH_VOLUME" > /dev/null 2>&1 || true

    # ホスト側で refresh 済みのトークンを常にボリュームに反映する。
    # Claude Code の OAuth トークンは短命なので、部屋起動ごとに最新を流し込む。
    local host_creds="${HOME}/.claude/.credentials.json"
    if [ -f "$host_creds" ]; then
        echo "[INFO] ホストの最新認証情報をボリュームに同期中..."
        docker run --rm \
            -v "${AUTH_VOLUME}:/dst" \
            -v "${host_creds}:/src/.credentials.json:ro" \
            -e HOST_UID="$(id -u)" \
            -e HOST_GID="$(id -g)" \
            --entrypoint /bin/bash \
            "$BASE_IMAGE" \
            -c "cp /src/.credentials.json /dst/.credentials.json && chown \$HOST_UID:\$HOST_GID /dst/.credentials.json && chmod 600 /dst/.credentials.json" \
            > /dev/null 2>&1 || echo "[WARN] 認証情報同期に失敗"
    else
        echo "[WARN] ホストに認証情報なし: $host_creds"
        echo "       spirit-room auth を先に実行してください"
    fi

    docker run -d \
        --name "$name" \
        --hostname "$name" \
        -e ROOM_NAME="$(basename $folder)" \
        -e CLAUDE_CONFIG_DIR=/workspace/.claude-home \
        -e HOST_UID="$(id -u)" \
        -e HOST_GID="$(id -g)" \
        -p "${port}:22" \
        -v "${folder}:/workspace" \
        -v "${AUTH_VOLUME}:/root/.claude-shared" \
        -v "${HOME}/.claude.json:/root/.host-claude.json:ro" \
        "$BASE_IMAGE"

    echo "[INFO] 界王星を開きました"
    echo ""
    echo "  ホスト側ログ  : spirit-room logs  $folder"
    echo "  再入室        : spirit-room enter $folder"
    echo ""
    echo "[INFO] tmux セッションにアタッチ中..."
    # entrypoint.sh が tmux を立ち上げるまで少し待つ
    sleep 2
    cmd_enter "$folder"
}

# ── 実行中のコンテナを解決 (spirit-room / 界王星 両対応) ─────
# 通常モード名が無ければ -kaio サフィックス付きを探す
resolve_running_name() {
    local base="$1"
    if docker ps --format '{{.Names}}' | grep -q "^${base}$"; then
        echo "$base"
    elif docker ps --format '{{.Names}}' | grep -q "^${base}-kaio$"; then
        echo "${base}-kaio"
    else
        echo ""
    fi
}

# ── コマンド: enter ──────────────────────────────────────────
cmd_enter() {
    local folder="${1:-$(pwd)}"
    folder=$(realpath "$folder")
    local base=$(folder_to_name "$folder")
    local name=$(resolve_running_name "$base")

    if [ -z "$name" ]; then
        echo "[ERROR] 部屋 '$base' (または '${base}-kaio') は起動していません"
        echo "  起動: spirit-room open $folder"
        echo "     または: spirit-room kaio $folder"
        exit 1
    fi

    local port=$(docker port "$name" 22 | cut -d: -f2)
    echo "[INFO] 部屋[$name] に入室 (SSH port: $port)"
    ssh -o StrictHostKeyChecking=no \
        -o UserKnownHostsFile=/dev/null \
        -t root@localhost -p "$port" \
        "tmux attach -t spirit-room || tmux new-session -s spirit-room"
}

# ── コマンド: list ───────────────────────────────────────────
cmd_list() {
    echo "起動中の部屋:"
    docker ps \
        --filter "name=spirit-room-" \
        --format "  {{.Names}}\t{{.Status}}\tSSH→{{.Ports}}" \
        | column -t
}

# ── コマンド: close ──────────────────────────────────────────
cmd_close() {
    local folder="${1:-$(pwd)}"
    folder=$(realpath "$folder")
    local base=$(folder_to_name "$folder")
    local name=$(resolve_running_name "$base")

    if [ -z "$name" ]; then
        echo "[ERROR] 部屋 '$base' (または '${base}-kaio') は起動していません"
        exit 1
    fi

    echo "[INFO] 部屋 '$name' を閉じます..."
    docker stop "$name" && docker rm "$name"
    echo "[INFO] 完了（workspaceのファイルはフォルダに残っています）"
}

# ── コマンド: logs ───────────────────────────────────────────
cmd_logs() {
    local folder="${1:-$(pwd)}"
    folder=$(realpath "$folder")
    echo "[INFO] ログ: $folder/.logs/progress.log"
    tail -f "$folder/.logs/progress.log" 2>/dev/null || echo "ログなし（まだ修行が始まっていません）"
}

# ── コマンド: auth ───────────────────────────────────────────
cmd_auth() {
    local creds="${HOME}/.claude/.credentials.json"
    docker volume create "$AUTH_VOLUME" > /dev/null 2>&1 || true

    if [ -f "$creds" ]; then
        # ホストに認証済みの場合: credentials をボリュームにコピー
        echo "[INFO] ホストの認証情報をボリュームにコピーします..."
        docker run --rm \
            -v "${AUTH_VOLUME}:/root/.claude" \
            -v "${creds}:/src/.credentials.json:ro" \
            --entrypoint /bin/bash \
            "$BASE_IMAGE" \
            -c "cp /src/.credentials.json /root/.claude/.credentials.json"
        echo "[INFO] 認証情報をボリューム '$AUTH_VOLUME' に保存しました"
        echo "[INFO] 以降の全部屋でこの認証が使われます"
    else
        # ホスト未認証の場合: 手順を案内
        echo ""
        echo "╔══════════════════════════════════════════════╗"
        echo "║  初回認証が必要です                         ║"
        echo "╚══════════════════════════════════════════════╝"
        echo ""
        echo "ホスト側で claude auth login を実行してください:"
        echo ""
        echo "  1. 別ターミナルで: claude auth login"
        echo "  2. 表示された URL をブラウザで開く"
        echo "  3. 認証コードをターミナルに貼り付ける"
        echo "  4. 完了後、再度このコマンドを実行: spirit-room auth"
        echo ""
        echo "[ERROR] ホストに認証情報が見つかりません: $creds"
        exit 1
    fi
}

# ── メイン ───────────────────────────────────────────────────
case "${1:-}" in
    open)   cmd_open  "${2:-}" ;;
    kaio)   cmd_kaio  "${2:-}" ;;
    enter)  cmd_enter "${2:-}" ;;
    list)   cmd_list ;;
    close)  cmd_close "${2:-}" ;;
    logs)   cmd_logs  "${2:-}" ;;
    auth)   cmd_auth ;;
    *)      usage ;;
esac
